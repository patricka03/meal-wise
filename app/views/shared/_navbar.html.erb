<nav class="navbar navbar-expand-sm navbar-light navbar-lewagon">
  <div class="container-fluid">

    <!-- LOGO -->

    <%= link_to "#", class: "navbar-brand" do %>
      <%= image_tag "https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/logo.png" %>
    <% end %>

    <!-- MOBILE TOGGLE -->

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarSupportedContent"
      aria-controls="navbarSupportedContent"
      aria-expanded="false"
      aria-label="Toggle navigation">

      <span class="navbar-toggler-icon"></span>

    </button>

    <!-- NAVBAR CONTENT -->

    <div class="collapse navbar-collapse"
         id="navbarSupportedContent">

      <ul class="navbar-nav me-auto align-items-center">

        <% if user_signed_in? %>

          <!-- HOME -->

          <li class="nav-item active">

            <%= link_to "Home",
                "#",
                class: "nav-link fw-semibold text-white" %>

          </li>


          <!-- RECIPES -->

          <li class="nav-item">

            <%= link_to "Recipes",
                "#",
                class: "nav-link fw-semibold text-white" %>

          </li>


          <!-- PROFILE DROPDOWN -->

          <li class="nav-item dropdown">

            <a href="#"
               class="avatar"
               id="navbarDropdown"
               data-bs-toggle="dropdown"
               aria-haspopup="true"
               aria-expanded="false">

              <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier",
                  class: "avatar",
                  alt: "dropdown menu" %>

            </a>

            <div class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 mt-3"
                 aria-labelledby="navbarDropdown">

              <%= link_to "My Recipes",
                  "#",
                  class: "dropdown-item py-2 text-success" %>

              <%= link_to "Favourites",
                  "#",
                  class: "dropdown-item py-2 text-success" %>

              <%= link_to "Profile",
                  "#",
                  class: "dropdown-item py-2 text-success" %>

              <hr>

              <%= link_to "Log out",
                  destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "dropdown-item py-2 text-danger" %>

            </div>

          </li>



        <% else %>

          <!-- SIGN IN BUTTON -->

          <li class="nav-item me-2">

            <button
              type="button"
              class="btn btn-outline-success rounded-pill px-4 fw-semibold"
              data-bs-toggle="modal"
              data-bs-target="#loginModal">

              Sign in

            </button>

          </li>

        <% end %>

      </ul>
    </div>
  </div>
</nav>



<!-- LOGIN MODAL -->

<div
  class="modal fade"
  id="loginModal"
  tabindex="-1"
  aria-labelledby="loginModalLabel"
  aria-hidden="true">

  <div class="modal-dialog modal-dialog-centered">

    <div class="modal-content border-0 rounded-4 shadow">

      <!-- HEADER -->

      <div class="modal-header border-0">

        <h5
          class="modal-title fw-bold"
          id="loginModalLabel">

          Welcome back

        </h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
          aria-label="Close">
        </button>

      </div>

      <!-- BODY -->

      <div class="modal-body px-4 pb-4">

        <p class="text-muted mb-4">
          Log in to continue
        </p>

        <!-- LOGIN FORM -->

        <%= simple_form_for(User.new,
            url: user_session_path) do |f| %>

          <%= f.input :email,
                      required: false,
                      autofocus: true,
                      label: "Email",
                      input_html: {
                        autocomplete: "email",
                        class: "rounded-3"
                      } %>

          <%= f.input :password,
                      required: false,
                      label: "Password",
                      input_html: {
                        autocomplete: "current-password",
                        class: "rounded-3"
                      } %>

          <%= f.input :remember_me,
                      as: :boolean %>

          <%= f.button :submit,
                       "Log in",
                       class: "btn btn-success w-100 rounded-pill py-2 fw-semibold mt-3" %>

        <% end %>



        <!-- SIGN UP LINK -->

        <div class="text-center mt-4">

          <span class="text-muted">
            Don't have an account?
          </span>

          <button
            type="button"
            class="btn btn-link text-success fw-semibold text-decoration-none p-0 ms-1"
            data-bs-dismiss="modal"
            data-bs-toggle="modal"
            data-bs-target="#signupModal">

            Sign up

          </button>

        </div>

      </div>
    </div>
  </div>
</div>


<!-- SIGNUP MODAL -->

<div
  class="modal fade"
  id="signupModal"
  tabindex="-1"
  aria-labelledby="signupModalLabel"
  aria-hidden="true">

  <div class="modal-dialog modal-dialog-centered">

    <div class="modal-content border-0 rounded-4 shadow">

      <!-- HEADER -->

      <div class="modal-header border-0">

        <h5
          class="modal-title fw-bold"
          id="signupModalLabel">

          Create account

        </h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
          aria-label="Close">
        </button>

      </div>

      <!-- BODY -->

      <div class="modal-body px-4 pb-4">

        <p class="text-muted mb-4">
          Join and start saving recipes
        </p>

        <!-- SIGNUP FORM -->

        <%= simple_form_for(User.new,
            url: user_registration_path) do |f| %>

          <%= f.input :email,
                      required: true,
                      autofocus: true,
                      label: "Email",
                      input_html: {
                        autocomplete: "email",
                        class: "rounded-3"
                      } %>

          <%= f.input :password,
                      required: true,
                      label: "Password",
                      input_html: {
                        autocomplete: "new-password",
                        class: "rounded-3"
                      } %>

          <%= f.input :password_confirmation,
                      required: true,
                      label: "Confirm password",
                      input_html: {
                        autocomplete: "new-password",
                        class: "rounded-3"
                      } %>

          <%= f.button :submit,
                       "Create account",
                       class: "btn btn-success w-100 rounded-pill py-2 fw-semibold mt-3" %>

        <% end %>

        <!-- LOGIN LINK -->

        <div class="text-center mt-4">

          <span class="text-muted">
            Already have an account?
          </span>

          <button
            type="button"
            class="btn btn-link text-success fw-semibold text-decoration-none p-0 ms-1"
            data-bs-dismiss="modal"
            data-bs-toggle="modal"
            data-bs-target="#loginModal">

            Log in

          </button>

        </div>

      </div>
    </div>
  </div>
</div>
