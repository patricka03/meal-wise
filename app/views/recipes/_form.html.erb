<%= simple_form_for(@recipe) do |f| %>
  <%= f.input :title %>
  <%= f.input :description %>
  <%= f.input :ingredients %>
  <%= f.input :instructions %>
  <%= f.input :cook_time %>
  <%= f.input :prep_time %>
  <%= f.input :servings %>
  <%= f.input :difficulty %>
  <%= f.input :category %>
  <%= f.submit %>
<% end %>
